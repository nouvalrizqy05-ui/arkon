# ============================================================
# ARKON Backend — Environment Variables Template
# Copy to .env and fill in your values
# NEVER commit .env to git
# ============================================================

# ─── Server ───────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ─── Database (PostgreSQL) ────────────────────────────────
# Option A: Full URL (recommended for Railway/Render)
DB_URL=postgresql://user:password@host:5432/arkon_production?sslmode=require

# Option B: Individual params (for local dev)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=arkon_dev
# DB_USER=postgres
# DB_PASSWORD=your_password

# ─── Redis ────────────────────────────────────────────────
# Required for Socket.io horizontal scaling and caching
# Get from Railway Redis addon or Upstash (free tier available)
REDIS_URL=redis://default:password@host:6379
REDIS_CACHE_TTL=30

# ─── Auth ─────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_64_CHARS_RANDOM_HEX
REFRESH_SECRET=CHANGE_ME_64_CHARS_RANDOM_HEX_DIFFERENT

# ─── AI (Gemini) ──────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key

# ─── File Storage (Cloudinary) ────────────────────────────
# Get from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Email (Resend) ───────────────────────────────────────
# Get from: https://resend.com
RESEND_API_KEY=re_your_key
EMAIL_FROM=noreply@yourdomain.com

# ─── CORS ─────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://arkon.yourdomain.com,https://www.arkon.yourdomain.com

# ─── Frontend URL (for email links) ──────────────────────
FRONTEND_URL=https://arkon.yourdomain.com

# ─── Feature Flags ────────────────────────────────────────
ENABLE_REGISTRATION=true
ENABLE_EMAIL_VERIFICATION=true
ENABLE_AI_FEATURES=true

# ─── Rate Limiting ────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ============================================================
# AZURE FOR STUDENTS — Konfigurasi Khusus
# ============================================================
# Gunakan salah satu opsi di bawah untuk PostgreSQL Azure:
#
# OPSI A: Connection String (lebih mudah)
# Salin dari: Azure Portal → Flexible Server → Connection strings → Node.js
# DATABASE_URL=postgresql://username:password@servername.postgres.database.azure.com:5432/arkon_db?sslmode=require
#
# OPSI B: Variabel Terpisah
AZURE_POSTGRESQL_HOST=servername.postgres.database.azure.com
AZURE_POSTGRESQL_PORT=5432
AZURE_POSTGRESQL_DATABASE=arkon_db
AZURE_POSTGRESQL_USER=username@servername
AZURE_POSTGRESQL_PASSWORD=password

# ─── Azure Cache for Redis ─────────────────────────────────
# WAJIB "rediss://" (double-s) untuk TLS di Azure!
# Salin dari: Azure Portal → Azure Cache for Redis → Access keys → Primary connection string
# Format: rediss://:<primary_key>@<name>.redis.cache.windows.net:6380
# Atau gunakan AZURE_REDIS_CONNECTIONSTRING (otomatis jika linked di App Service)
# AZURE_REDIS_CONNECTIONSTRING=rediss://:primarykey@yourname.redis.cache.windows.net:6380

# ─── Azure App Service (otomatis diisi oleh Azure) ─────────
# Variabel ini diset otomatis oleh Azure — jangan isi manual kecuali di-docker-compose
# AZURE_WEBAPP_NAME=arkon-backend
# WEBSITE_SITE_NAME=arkon-backend

# ─── GitHub Actions Secrets yang harus diisi ───────────────
# Tambahkan ke: GitHub → Settings → Secrets and variables → Actions
# AZURE_WEBAPP_PUBLISH_PROFILE_BACKEND  (dari App Service → Get publish profile)
# AZURE_STATIC_WEB_APPS_API_TOKEN       (dari Static Web Apps → Manage deployment token)
# AZURE_BACKEND_URL                     (https://arkon-backend.azurewebsites.net)

# ─── Monitoring (Sentry) ──────────────────────────────────
# Buat project di https://sentry.io → Node.js → copy DSN
# Jika tidak diisi, error monitoring di-skip (tidak error)
SENTRY_DSN=

# ─── API Docs Protection (Production) ─────────────────────
# Swagger docs di /api/docs dilindungi dengan key ini di production
# Akses: https://your-api.com/api/docs?key=YOUR_DOCS_KEY
DOCS_API_KEY=ganti_dengan_random_string_aman

# ─── Health Check Alerting ────────────────────────────────
# Webhook URL untuk notifikasi alert dari scripts/health-check.sh
# Mendukung Telegram Bot API atau Slack Incoming Webhook
# Contoh Telegram: https://api.telegram.org/bot<TOKEN>/sendMessage
# Contoh Slack:    https://hooks.slack.com/services/XXX/YYY/ZZZ
# Kosongkan jika tidak ingin notifikasi otomatis
ALERT_WEBHOOK=

# ─── Onboarding & Multi-tenant ────────────────────────────
# Set ke false untuk skip email verification saat development
# ENABLE_EMAIL_VERIFICATION=false
