# ==================================
# ARKON Docker Development Environment
# ==================================

# Node Environment
NODE_ENV=development
PORT=3000

# ========== DATABASE ==========
DB_USER=postgres
DB_HOST=postgres
DB_NAME=arkon_db
DB_PASSWORD=docker_dev_password
DB_PORT=5432

# ========== JWT SECRETS ==========
# Note: These are development keys. Change in production!
JWT_SECRET=dev-jwt-secret-key-change-in-production
REFRESH_SECRET=dev-refresh-secret-key-change-in-production

# ========== GOOGLE GEMINI AI ==========
# Get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash,gemini-2.0-flash-lite

# ========== CORS ==========
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173,http://127.0.0.1:3000

# ========== CLOUDINARY (Optional) ==========
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ========== EMAIL (Optional) ==========
RESEND_API_KEY=

# ========== FRONTEND ==========
VITE_API_URL=http://localhost:3000
